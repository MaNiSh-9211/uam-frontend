# uam-frontend/.env.example — template (committed)

VITE_API_URL=/api
UAM_FRONTEND_PORT=8091

# Render — use private network (Connect → Internal on gateway-edge service).
# Public onrender.com proxy URLs cause 508 loop detected between Render web services.
# GATEWAY_INTERNAL_HOST=your-gateway-internal-hostname
# GATEWAY_INTERNAL_PORT=8080

# Alternative (local / non-Render only):
# GATEWAY_PROXY_PASS=http://gateway:8080/api/
# GATEWAY_PROXY_HOST=gateway

# Gateway proxy — set in Render dashboard only (do not commit production URLs).
# Local Compose uses docker-entrypoint.sh defaults (gateway:8080).
# GATEWAY_PROXY_PASS=https://YOUR-GATEWAY.onrender.com/api/
# GATEWAY_PROXY_HOST=YOUR-GATEWAY.onrender.com
